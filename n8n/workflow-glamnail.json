{
  "name": "GlamNail - WhatsApp Notifications",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "glamnail",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "glamnail"
    },
    {
      "parameters": {
        "url": "http://localhost:3000/message/sendText/glamnail",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sua_api_key_aqui"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "number",
              "value": "={{ $json.appointment.client.phone }}"
            },
            {
              "name": "text",
              "value": "={{ $json.businessName }} - Olá {{ $json.appointment.client.name }}! Seu agendamento foi realizado com sucesso para {{ $json.appointment.date }}. Serviços: {{ $json.appointment.services.map(s => s.service.name).join(', ') }}. Obrigado!"
            }
          ]
        },
        "options": {}
      },
      "id": "sendWhatsApp",
      "name": "Enviar WhatsApp - Criado",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 300]
    },
    {
      "parameters": {
        "url": "http://localhost:3000/message/sendText/glamnail",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sua_api_key_aqui"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "number",
              "value": "={{ $json.appointment.client.phone }}"
            },
            {
              "name": "text",
              "value": "={{ $json.businessName }} - Olá {{ $json.appointment.client.name }}! Seu agendamento foi CONFIRMADO para {{ $json.appointment.date }}. Serviços: {{ $json.appointment.services.map(s => s.service.name).join(', ') }}. Nos vemos lá!"
            }
          ]
        },
        "options": {}
      },
      "id": "sendConfirm",
      "name": "Enviar WhatsApp - Confirmado",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 450]
    },
    {
      "parameters": {
        "url": "http://localhost:3000/message/sendText/glamnail",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sua_api_key_aqui"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "number",
              "value": "={{ $json.appointment.client.phone }}"
