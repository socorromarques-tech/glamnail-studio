            {
              "name": "text",
              "value": "={{ $json.businessName }} - Olá {{ $json.appointment.client.name }}! Seu agendamento foi CANCELADO ({{ $json.appointment.date }}). Se precisar, agende novamente!"
            }
          ]
        },
        "options": {}
      },
      "id": "sendCancel",
      "name": "Enviar WhatsApp - Cancelado",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 600]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event }}",
              "operation": "equals",
              "value2": "appointment.created"
            }
          ]
        },
        "options": {}
      },
      "id": "filterCreated",
